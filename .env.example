# ========================================
# 🤖 JagX WhatsApp Bot v3.0.0
# Created by JRILICENSE & JagX
# ========================================

# ========================================
# BASIC CONFIGURATION
# ========================================
PHONE_NUMBER=2349160654415
BOT_NAME=JagX Bot
BOT_PREFIX=.

# ========================================
# BOT BEHAVIOR
# ========================================
AUTO_READ=true
AUTO_TYPING=true
AUTO_RECORDING=true
DEBUG=false
VERBOSE_LOGS=false

# ========================================
# SERVER CONFIGURATION (Multi-Server Support)
# ========================================
# Primary Server
PRIMARY_SERVER=https://server1.example.com
PRIMARY_SERVER_AUTH_KEY=your_primary_server_key

# Secondary Servers (40+ servers support)
SERVER_2=https://server2.example.com
SERVER_2_AUTH_KEY=your_server_2_key

SERVER_3=https://server3.example.com
SERVER_3_AUTH_KEY=your_server_3_key

SERVER_4=https://server4.example.com
SERVER_4_AUTH_KEY=your_server_4_key

SERVER_5=https://server5.example.com
SERVER_5_AUTH_KEY=your_server_5_key

SERVER_6=https://server6.example.com
SERVER_6_AUTH_KEY=your_server_6_key

SERVER_7=https://server7.example.com
SERVER_7_AUTH_KEY=your_server_7_key

SERVER_8=https://server8.example.com
SERVER_8_AUTH_KEY=your_server_8_key

SERVER_9=https://server9.example.com
SERVER_9_AUTH_KEY=your_server_9_key

SERVER_10=https://server10.example.com
SERVER_10_AUTH_KEY=your_server_10_key

# Add more servers (11-40) as needed - format: SERVER_[N]=<URL>
# SERVER_11 through SERVER_40 can be added here

# ========================================
# WEBSOCKET & CONNECTION
# ========================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=8080
CONNECTION_TIMEOUT=30000
RECONNECT_INTERVAL=5000
MAX_RECONNECTION_ATTEMPTS=10

# ========================================
# DATABASE & STORAGE
# ========================================
DATABASE_URL=mongodb://localhost:27017/jagx_bot
USE_LOCAL_STORAGE=true
STORAGE_PATH=./data/storage
SESSION_PATH=./sessions
LOGS_PATH=./logs

# ========================================
# FEATURES CONFIGURATION
# ========================================
# Message Features
ENABLE_VIEW_ONCE=true
ENABLE_MESSAGE_RECALL=true
ENABLE_AUTO_REPLY=true
ENABLE_SCHEDULED_MESSAGES=true
ENABLE_BULK_MESSAGING=true
ENABLE_MESSAGE_REACTIONS=true
ENABLE_MESSAGE_EDITING=true
ENABLE_MESSAGE_FORWARDING=true
ENABLE_PIN_MESSAGES=true
ENABLE_MESSAGE_SEARCH=true

# Group Management
ENABLE_GROUP_WELCOME=true
ENABLE_GROUP_RULES=true
ENABLE_GROUP_INFO=true
ENABLE_MEMBER_COUNT=true
ENABLE_ADMIN_PROMOTE=true
ENABLE_ADMIN_DEMOTE=true
ENABLE_MEMBER_REMOVE=true
ENABLE_GROUP_DESCRIPTION=true
ENABLE_GROUP_ICON=true
ENABLE_GROUP_SETTINGS=true

# Media Handling
ENABLE_IMAGE_RECOGNITION=true
ENABLE_VIDEO_PROCESSING=true
ENABLE_AUDIO_CONVERSION=true
ENABLE_STICKER_CREATION=true
ENABLE_DOCUMENT_CONVERSION=true
ENABLE_PDF_GENERATION=true
ENABLE_IMAGE_COMPRESSION=true
ENABLE_VIDEO_COMPRESSION=true
ENABLE_QR_CODE_GENERATOR=true
ENABLE_SCREENSHOT_TAKER=true

# Search & Information
ENABLE_GOOGLE_SEARCH=true
ENABLE_WEATHER_INFO=true
ENABLE_NEWS_UPDATES=true
ENABLE_CURRENCY_CONVERTER=true
ENABLE_UNIT_CONVERTER=true
ENABLE_DICTIONARY=true
ENABLE_TRANSLATOR=true
ENABLE_IP_LOOKUP=true
ENABLE_URL_SHORTENER=true
ENABLE_LYRICS_FINDER=true

# Entertainment
ENABLE_MUSIC_PLAYER=true
ENABLE_MEME_GENERATOR=true
ENABLE_JOKE_GENERATOR=true
ENABLE_QUOTE_GENERATOR=true
ENABLE_GAME_STARTER=true
ENABLE_TRIVIA_QUIZ=true
ENABLE_RIDDLE_MASTER=true
ENABLE_STORY_GENERATOR=true
ENABLE_ASCII_ART=true
ENABLE_POEM_GENERATOR=true

# Utilities
ENABLE_HELP_MENU=true
ENABLE_BOT_STATUS=true
ENABLE_UPTIME_INFO=true
ENABLE_SETTINGS=true
ENABLE_FEEDBACK=true
ENABLE_ADMIN_COMMANDS=true

# ========================================
# API KEYS & EXTERNAL SERVICES
# ========================================
# Google APIs
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# Weather API
WEATHER_API_KEY=your_weather_api_key
WEATHER_SERVICE=openweathermap

# Translation
TRANSLATOR_API_KEY=your_translator_key

# News API
NEWS_API_KEY=your_news_api_key

# Lyrics API
LYRICS_API_KEY=your_lyrics_api_key

# IP Lookup
IPINFO_API_KEY=your_ipinfo_key

# URL Shortener
SHORTENER_API_KEY=your_shortener_key

# ========================================
# TERMUX & ANDROID SUPPORT
# ========================================
TERMUX_MODE=false
ANDROID_STORAGE_ACCESS=true
ALLOW_TERMUX_COMMANDS=true
TERMUX_ALERT_NOTIFICATIONS=true

# ========================================
# PERFORMANCE & OPTIMIZATION
# ========================================
ENABLE_CACHING=true
CACHE_TTL=3600
MAX_MESSAGE_SIZE=65536
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_CLUSTERING=false
MAX_WORKERS=4

# ========================================
# SECURITY
# ========================================
ENCRYPTION_ENABLED=true
JWT_SECRET=your_jwt_secret_key
API_SECRET=your_api_secret_key
REQUIRE_AUTH=true
ALLOWED_USERS=all
BLOCKED_USERS=

# ========================================
# MONITORING & LOGGING
# ========================================
LOG_LEVEL=info
ENABLE_ERROR_TRACKING=true
SENTRY_DSN=your_sentry_dsn
ENABLE_PERFORMANCE_MONITORING=true
SAVE_LOGS_TO_FILE=true
LOG_ROTATION_ENABLED=true
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# ========================================
# BACKUP & MAINTENANCE
# ========================================
ENABLE_AUTO_BACKUP=true
BACKUP_INTERVAL=86400
BACKUP_PATH=./backups
ENABLE_CLEANUP=true
CLEANUP_INTERVAL=604800

# ========================================
# ADVANCED SETTINGS
# ========================================
REAL_TIME_SYNC=true
ENABLE_BLOCKCHAIN_LOGGING=false
ENABLE_ANALYTICS=true
ANALYTICS_ENDPOINT=https://analytics.example.com
UPDATE_CHECK_ENABLED=true
VERSION_CHECK_URL=https://api.github.com/repos/Jwans/JagX-WhatsApp-bot/releases/latest

# ========================================
# PORT CONFIGURATION
# ========================================
HTTP_PORT=3000
HTTPS_PORT=3443
USE_HTTPS=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ========================================
# LICENSE & COMPLIANCE
# ========================================
LICENSE_TYPE=JRILICENSE
LICENSE_VERSION=1.0
AUTO_UPDATE_LICENSE=true
ACCEPT_TERMS_OF_SERVICE=true
